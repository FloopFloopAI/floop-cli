{
  "name": "@floopfloop/cli",
  "version": "0.1.0-alpha.7",
  "description": "Command-line interface for FloopFloop",
  "type": "module",
  "bin": {
    "floop": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "compile:linux-x64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-linux-x64 --outfile=dist/floop-linux-x64",
    "compile:darwin-x64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-darwin-x64 --outfile=dist/floop-darwin-x64",
    "compile:darwin-arm64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-darwin-arm64 --outfile=dist/floop-darwin-arm64",
    "compile:windows-x64": "bun build src/index.ts --compile --minify --sourcemap --target=bun-windows-x64 --outfile=dist/floop-windows-x64.exe",
    "compile:all": "npm run compile:linux-x64 && npm run compile:darwin-x64 && npm run compile:darwin-arm64 && npm run compile:windows-x64"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "open": "^11.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25",
    "tsup": "^8",
    "typescript": "^6"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["floopfloop", "cli", "vibe-coding"],
  "license": "MIT"
}
